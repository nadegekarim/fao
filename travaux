													<e:GroupingInputBlock.Title>
														<Span Class="bigger">
															<e:Output Ref="Titre"/>
														</Span>
													</e:GroupingInputBlock.Title>
													<my:GenericMobilitPersonnalise/>
												</e:GroupingInputBlock>
												<d:If.Else>
													<my:GenericMobilitInterview/>
												</d:If.Else>
											</d:If>
										</d:If>
									</d:If.Else>
								</d:If>
							</d:Case>
							<d:Case Value="bloccontenuopt">
								<d:If ConditionExpr="dbtboolean(IsPersonnalise)">
									<e:GroupingBlock Css.BackgroundColor="LemonChiffon">
										<e:GroupingBlock.Title>
											<Span Class="bigger">
												<e:Output Ref="Titre"/>
											</Span>
											<e:RadioButton Ref="IsVisible" Value="O" />
											<e:Label >Sans rénumération</e:Label>
											<e:RadioButton Ref="IsVisible"  Value="N" />
											<e:Label >Avec rénumération</e:Label>
											<e:RadioButton Ref="IsVisible"  Value="P" />
											<e:Label >Non</e:Label>
											<DataNodeListener Ref="IsVisible" Submission="RefreshChamps"/>
										</e:GroupingBlock.Title>
										<my:GenericChampsSimple/>
									</e:GroupingBlock>
									<d:If.Else>
										<d:If ConditionExpr ="IsVisible != 'P'">
											<e:GroupingBlock>
												<e:GroupingBlock.Title>
													<Span Class="bigger">
														<e:Output Ref="Titre"/>
													</Span>
												</e:GroupingBlock.Title>
												<!--Champs-->
												<my:GenericChampsSimple/>
											</e:GroupingBlock>
										</d:If>
									</d:If.Else>
								</d:If>

							</d:Case>
						</d:Switch>
					</d:If>
				</d:If.Else>
			</d:If>

		</d:If>
	</d:Foreach>
</Div>
